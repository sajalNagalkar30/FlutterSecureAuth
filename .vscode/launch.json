{
    "version": "0.2.0",
    "configurations": [

        // ─── Backend (local) ─────────────────────────────────────────────────
        {
            "name": "Start Backend",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/backend/server.js",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen",
            "restart": true
        },

        // ─── Flutter – Render (cloud backend, any device) ────────────────────
        {
            "name": "Flutter (Render Backend)",
            "type": "dart",
            "request": "launch",
            "cwd": "${workspaceFolder}/app/flutter_login_registration",
            "args": ["--dart-define=BASE_URL=https://fluttersecureauth.onrender.com/api/auth"]
        },

        // ─── Flutter – iOS Physical Device (local backend) ───────────────────
        {
            "name": "Flutter (iOS Physical - Local)",
            "type": "dart",
            "request": "launch",
            "cwd": "${workspaceFolder}/app/flutter_login_registration",
            "args": ["--dart-define=BASE_URL=https://10.45.44.173:9000/api/auth"]
        },

        // ─── Flutter – iOS Simulator (local backend) ─────────────────────────
        {
            "name": "Flutter (iOS Simulator - Local)",
            "type": "dart",
            "request": "launch",
            "cwd": "${workspaceFolder}/app/flutter_login_registration",
            "deviceId": "iphone",
            "args": ["--dart-define=BASE_URL=https://localhost:9000/api/auth"]
        },

        // ─── Flutter – Android Emulator (local backend) ──────────────────────
        {
            "name": "Flutter (Android Emulator - Local)",
            "type": "dart",
            "request": "launch",
            "cwd": "${workspaceFolder}/app/flutter_login_registration",
            "deviceId": "emulator",
            "args": ["--dart-define=BASE_URL=https://10.0.2.2:9000/api/auth"]
        },

        // ─── Flutter – Android Physical Device (local backend) ───────────────
        {
            "name": "Flutter (Android Physical - Local)",
            "type": "dart",
            "request": "launch",
            "cwd": "${workspaceFolder}/app/flutter_login_registration",
            "args": ["--dart-define=BASE_URL=https://10.45.44.173:9000/api/auth"]
        }
    ],

    // ─── Compounds ───────────────────────────────────────────────────────────
    "compounds": [
        {
            "name": "▶  Flutter (Render Backend)",
            "configurations": ["Flutter (Render Backend)"],
            "stopAll": true,
            "presentation": { "order": 1 }
        },
        {
            "name": "▶  Backend + iOS Physical",
            "configurations": ["Start Backend", "Flutter (iOS Physical - Local)"],
            "stopAll": true,
            "presentation": { "order": 2 }
        },
        {
            "name": "▶  Backend + Android Emulator",
            "configurations": ["Start Backend", "Flutter (Android Emulator - Local)"],
            "stopAll": true,
            "presentation": { "order": 3 }
        },
        {
            "name": "▶  Backend + Android Physical",
            "configurations": ["Start Backend", "Flutter (Android Physical - Local)"],
            "stopAll": true,
            "presentation": { "order": 4 }
        }
    ]
}
