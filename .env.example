PORT=9000

MONGO_URI=mongodb://localhost:27017/demo-login-app

# Secret for short-lived access tokens (15 min)
JWT_SECRET=your_strong_jwt_secret_here

# Secret for long-lived refresh tokens (7 days) — use a DIFFERENT value
JWT_REFRESH_SECRET=your_strong_refresh_secret_here

# Set to true to enable HTTPS (requires backend/certs/server.key + server.crt)
USE_HTTPS=false

# Comma-separated allowed origins for CORS (use * for dev only)
CORS_ORIGIN=*
